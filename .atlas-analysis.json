  "keyFeatures": [
    "Parallel multi-host deployment via deploy.sh using sshpass",
    "Automated iptables firewall lockdown based on port-sources config",
    "User hardening: locks all shells to /bin/false, adds bluey admin user",
    "Watchdawg file integrity monitor with backup and change detection",
    "C2 connection scanner with optional process kill mode (angryc2scanner)",
    "Competition-state backup covering filesystem, services, packages, and ports",
    "Interactive baselining with clean vs. dirty system diff comparison",
    "Auditd rules deployment with Discord webhook alerting"
  ],
  "publicApiSurface": [
